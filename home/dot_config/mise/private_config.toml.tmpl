{{- $profile := .profile -}}

[settings]
experimental = true

[tools]
{{- range (index .mise $profile.key).tools }}
{{ .name | quote }} = {{ $version := default "latest" (index . "version") -}}
{{- if eq (kindOf $version) "slice" -}}
[{{- range $i, $v := $version }}{{ if $i }}, {{ end }}"{{ $v }}"{{ end }}]
{{- else -}}
"{{ $version }}"
{{- end }}
{{- end }}

[env]
{{- range (index .mise $profile.key).env }}
{{- $secret := index . "secret" }}
{{- $value := index . "value" }}
{{- if $secret }}
{{ .name }} = "{{ onepasswordRead (printf "op://%s/%s" $profile.op.vault $secret) $profile.op.account }}"
{{- else if $value }}
{{ .name }} = "{{ $value }}"
{{- end }}
{{- end }}
