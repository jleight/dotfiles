# PATH
{{- if stat "/opt/homebrew/opt/curl/bin" }}
export PATH="/opt/homebrew/opt/curl/bin:$PATH"
{{- end }}
{{- if stat "/opt/homebrew/opt/openssl@3/bin" }}
export PATH="/opt/homebrew/opt/openssl@3/bin:$PATH"
{{- end }}
{{- if stat (joinPath .chezmoi.homeDir ".dotnet/tools") }}
export PATH="$PATH:$HOME/.dotnet/tools"
{{- end }}
{{- if stat (joinPath .chezmoi.homeDir ".krew/bin") }}
export PATH="$PATH:$HOME/.krew/bin"
{{- end }}
{{- if stat (joinPath .chezmoi.homeDir "go/bin") }}
export PATH="$PATH:$HOME/go/bin"
{{- end }}
export PATH="$HOME/.local/bin:$PATH"

# Aliases
{{- if lookPath "bat" }}
alias cat="bat --paging=never"
{{- end }}
alias cwd="pwd | tr -d '\n' | pbcopy"
{{- if lookPath "tofu" }}
alias terraform="tofu"
alias tf="tofu"
{{- end }}
{{- if lookPath "nvim" }}
alias vim="nvim"
{{- end }}

# Disable OMZ updates
zstyle ':omz:update' mode disabled

# Only re-initialize completions once per day
autoload -Uz compinit
if [ "$(date +'%j')" != "$(stat -f '%Sm' -t '%j' ~/.zcompdump 2>/dev/null)" ]; then
	compinit
else
	compinit -C
fi

# Enable OMZ plugins
plugins=(
{{- range .omz.plugins }}
{{- if lookPath (default .name (index . "test")) }}
	{{ .name }}
{{- end }}
{{- end }}
)

# Set OMZ theme
ZSH_THEME={{ .omz.theme | quote }}

# Include OMZ
export ZSH="${HOME}/.oh-my-zsh"
source "${ZSH}/oh-my-zsh.sh"

# Capture shell history with Atuin
eval "$(atuin init zsh)"
